# Google Sheets
GOOGLE_SHEETS_ID=your_google_sheet_id
GOOGLE_FORM_RESPONSE_SHEET=Form Responses 1

# Google API Credentials (JSON file path)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_EMAILS=admin@example.com

# JWT
JWT_SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=localhost
API_PORT=8000
ENVIRONMENT=development
DEBUG=True

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Render Deployment
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxxx
